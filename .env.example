# Optional database override. Defaults to ./data/app.db.
# JOB_RESEARCHER_DATABASE_URL=sqlite:///./data/app.db

# Optional data directory override. Defaults to ./data.
# JOB_RESEARCHER_DATA_DIR=./data

# Optional OpenAI-compatible API key. Do not commit a real key.
# OPENAI_API_KEY=

# Optional local browser executable for Playwright-backed collectors.
# JOB_HARVEST_BROWSER_EXECUTABLE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Optional Python interpreter used by the npm wrapper.
# JOB_RESEARCHER_PYTHON=/absolute/path/to/python
